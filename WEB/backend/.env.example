# -------------------------------------------------------
# Mercado Pago — get from mercadopago.com.mx/developers/panel
# Use TEST- prefixed tokens for sandbox testing
# -------------------------------------------------------
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# -------------------------------------------------------
# Google Sheets — service account credentials
# See setup instructions in README or the plan doc
# -------------------------------------------------------

# The spreadsheet ID from the URL:
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SPREADSHEET_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Service account email (from the JSON key file)
GOOGLE_SERVICE_ACCOUNT_EMAIL=ipf-backend@your-project.iam.gserviceaccount.com

# Private key from the JSON key file.
# Copy the "private_key" value (including -----BEGIN/END----- lines).
# Replace every actual newline with the literal two characters \n
# Example: "-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# -------------------------------------------------------
# App config
# -------------------------------------------------------

# Course prices in MXN (whole numbers, no decimals)
# Launch price for both diplomados: $4,500 MXN
PRICE_PAREJA=4500
PRICE_DESARROLLO=4500

# Your Netlify site URL — used for CORS whitelist (no trailing slash)
FRONTEND_ORIGIN=https://YOUR-SITE.netlify.app

# This server's own public URL — used to build the MP notification_url
# Set after Railway assigns a URL, then redeploy
BACKEND_URL=https://YOUR-BACKEND.railway.app

# Set to "production" on Railway; leave blank or "development" locally
NODE_ENV=development

# -------------------------------------------------------
# Email (Resend HTTP API) - confirmation email sent on approved payment.
# Sent over HTTPS/443 (Railway blocks outbound SMTP, so SMTP is not usable).
# RESEND_API_KEY: create at resend.com/api-keys.
# To send from contacto@personayfamilia.org you must verify that domain in
# Resend (add the SPF/DKIM DNS records it gives you). Until the domain is
# verified, Resend only allows EMAIL_FROM=onboarding@resend.dev to your own
# verified address (use that for testing).
# -------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Instituto Persona y Familia <contacto@tudominio.com>

# -------------------------------------------------------
# WhatsApp group invite links (one per diplomado)
# Sent inside the confirmation email so enrollees can join their cohort
# -------------------------------------------------------
WHATSAPP_PAREJA=https://chat.whatsapp.com/XXXXXXXX
WHATSAPP_DESARROLLO=https://chat.whatsapp.com/YYYYYYYY

# Seminario-taller "¿Estás viviendo o solo estás sobreviviendo?"
PRICE_SEMINARIO=200
WHATSAPP_SEMINARIO=https://chat.whatsapp.com/REEMPLAZAR
